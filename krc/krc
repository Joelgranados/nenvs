#!/usr/bin/env bash
# SPDX-License-Identifier: GPL-3.0-only

: "${KRC_LOCALVERSION:=""}"
PWD=$(pwd)
ENVS_GIT_REPO="github:Joelgranados/nenvs/master"
TC_GIT_REPO="github:Joelgranados/toolchain_ctl"
TC_CTL_CMD="nix shell ${TC_GIT_REPO} --impure -c toolchain_ctl"
BASENAME="$(basename "${BASH_SOURCE[0]}")"
USAGE="
Usage: ${BASENAME} [OPTIONS] <HOST> -- <COMMAND>

  Execute <COMMAND> in <HOST> through ssh connection.
  A mutagen session for PWD must exist.

HOST      Name of ssh-able host
COMMAND   Command to append

OPTIONS:
  -x, --cross-compile <ARCH>  Setup a cross-compilation environment for ARCH
                              just before executing <COMMAND>. Architecture
                              strings that work for Linux's ARCH argument should
                              work here.
  -e, --env <ENV>             Environment name under ${ENVS_GIT_REPO} to use
                              for the command. Valid values are kernel_base and
                              qemu_base. kernel_base is default.
  -m, --mutagen-create        Runs 'mutagen sync create' before any other mutagen
                              command.
  -v, --verbose               Increase verbosity
  --skip-wait                 Return immediately after calling flushing mutagen
                              and leave the session un-paused.
  --print                     Output the Heredoc that would have been executed.

ENV VARS:
  KRC_LOCALVERSION            prefix this var to control LOCALVERSION=
"
_usage() {
    if [[ $2 -ne 0 ]]; then
        echo "$1" >&2
        exit "$2"
    fi
    echo "$1"
    exit 0
}

add_xcompile_cmds()
{
  local arch="$1"
  echo "toolchain_ctl arch_wget ${arch} && toolchain_ctl arch_env ${arch}"
}

get_krc_opts()
{
  local short="x:e:vhm"
  local long="cross-compile:,env:,verbose,skip-wait,help,print,mutagen-create"

  if ! tmp=$(getopt -o "$short" --long "$long" -n "$BASENAME" -- "$@"); then
    exit 1
  fi
  eval set -- "$tmp"
  unset tmp

  while true; do
    case "$1" in
      '-x' | '--cross-compile' )
        xcomp_arch=$2; shift 2
        ;;

      '-e' | '--env' )
        ENV_URL="${ENVS_GIT_REPO}\?dir=$2"; shift 2
        ;;

      '--skip-wait' )
        skip_wait=1; shift
        ;;

      '-h' | '--help' )
        _usage "${USAGE}" 0
        ;;

      '-v' | '--verbose' )
        VERBOSE=1; shift
        ;;

      '-m' | '--mutagen-create' )
        mutagen_create=1; shift
        ;;

      '--print' )
        PRINT=1; shift;
        ;;

      '--' )
        shift 1; break
        ;;

      * )
        _usage "${USAGE}" 1
        ;;

    esac
  done

  shift $((OPTIND -1))
  # Make sure args are: "$@ = HOST COMMAND"
  if [ $# -lt 2 ]; then
    echo "Error: You are missing an argument"
    _usage "${USAGE}" 1
  fi

  HOST=$1; shift 1;

  # Update args after filtering out [OPTIONS]
  cmd_args="$*"

  xcompile_cmds=""
  if [[ -v xcomp_arch ]]; then
    xcompile_cmds="
      ${TC_CTL_CMD} arch_wget ${xcomp_arch}
      eval \$(${TC_CTL_CMD} arch_export ${xcomp_arch})"
  fi

  if [[ ! -v ENV_URL ]]; then
    ENV_URL="${ENVS_GIT_REPO}\?dir=kernel_base"
  fi

  MUT_SESS_NAME="$(echo "${PWD}" | sed "s./..g")${HOST}"

  NIX_DEV_ARGS="--no-write-lock-file "
  NIX_DEV_ARGS+="-i "
  # https://www.kernel.org/doc/html/latest/kbuild/reproducible-builds.html#timestamps
  NIX_DEV_ARGS+="-s KBUILD_BUILD_TIMESTAMP 0 "
  NIX_DEV_ARGS+="-s KBUILD_BUILD_USER user "
  NIX_DEV_ARGS+="-s KBUILD_BUILD_HOST host "
  NIX_DEV_ARGS+="-s KBUILD_BUILD_VERSION 1 "
  NIX_DEV_ARGS+="-s LOCALVERSION \"${KRC_LOCALVERSION}\" "

  HEREDOC_SCRIPT="
    # Adjust PATH for non-login shells connecting to non-nix hosts
    # with nix packages installed
    if ! echo \$PATH | grep 'nix.profile' > /dev/null ; then
      PATH=\"~/.nix-profile/bin:/nix/var/nix/profiles/default/bin:\$PATH\"
    fi

    ${xcompile_cmds}

    cd ${PWD} && nix develop ${NIX_DEV_ARGS} ${ENV_URL} --command bash -c \"${cmd_args}\"
  "
}

_silent_exec() {
  eval "${1}"
}

_exec() {
  local cmd="${1}"

  if [[ -v VERBOSE || -v PRINT ]]; then
    echo "${cmd}"
  fi

  if [[ -v PRINT ]]; then
    return 0
  fi

  _silent_exec "${cmd}"
  res="$?"

  if [ "$res" != 0 ]; then
    echo -e "error cmd (${cmd}) \n err: $res"
    _usage "${USAGE}" 1
  fi
}

mutagen_sync_pause()
{
  local sess=$1
  local cmd="mutagen sync resume ${sess} \
    && mutagen sync flush ${sess} \
    && mutagen sync pause ${sess}"
  _exec "${cmd}"
}

mutagen_sync_nopause()
{
  local sess=$1
  local cmd="mutagen sync resume ${sess} \
    && mutagen sync flush --skip-wait ${sess}"
  _exec "${cmd}"

}

mutagen_create()
{
  local sess="$1"
  local host="$2"
  local cmd="mutagen sync create --name ${sess} \
    -p -m two-way-resolved --ignore-vcs --symlink-mode=posix-raw \
    ${PWD} ${host}:${PWD}"
  _exec "${cmd}"
}

remote_exec()
{
  mutagen_sync_pause "${MUT_SESS_NAME}"

  local cmd="ssh \"${HOST}\" bash -c '${HEREDOC_SCRIPT}'"
  _exec "${cmd}"

  if [[ -v skip_wait ]]; then
    mutagen_sync_nopause "${MUT_SESS_NAME}"
  else
    mutagen_sync_pause "${MUT_SESS_NAME}"
  fi
}

local_exec()
{
  local cmd="bash -c '${HEREDOC_SCRIPT}'"
  _exec "${cmd}"
}

get_krc_opts "$@"

if [[ -v mutagen_create ]]; then 
  mutagen_create "${MUT_SESS_NAME}" "${HOST}"
fi

if [[ ${HOST} == "localhost" ]]; then
  local_exec
else
  remote_exec
fi

